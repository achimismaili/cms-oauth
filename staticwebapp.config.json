{
  "platform": {
    "apiRuntime": "node:22"
  },
  "routes": [
    {
      "route": "/auth",
      "rewrite": "/api/auth"
    },
    {
      "route": "/callback",
      "rewrite": "/api/callback"
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"],
      "headers": {
        "Cache-Control": "no-store, must-revalidate",
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff"
      }
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
